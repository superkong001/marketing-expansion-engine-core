{
  "_comment": "AICohortInsight 统一配置文件。修改本文件即可调整 Stage1/Stage2 参数与开关，无需改代码。",
  "stage1": {
    "_comment": "阶段1：特征差异计算与阈值推荐",
    "top_k_numeric": 50,
    "top_k_categorical": 30,
    "target_ratio": null,
    "distribution": {
      "_comment": "分布类型检测（analyze_distributions）：skew_eps 偏度阈值，tail_thr 尾部比阈值",
      "skew_eps": 0.2,
      "tail_thr": 0.5,
      "eps": 1e-9
    },
    "numeric_threshold": {
      "_comment": "连续特征阈值推荐（仅作 debug，不参与决策）；output_candidate_family 输出候选族",
      "min_cohort_coverage": 0.1,
      "min_lift": 1.2,
      "max_base_cov_for_numeric": 0.15,
      "output_candidate_family": true,
      "upper_quantiles": [0.7, 0.8, 0.9, 0.95],
      "lower_quantiles": [0.3, 0.2, 0.1, 0.05],
      "dedup_overlap_threshold": 0.8
    },
    "categorical_threshold": {
      "_comment": "离散特征类别推荐：min_delta 最小差异，min_cov 最小覆盖率，min_increment 边际增量",
      "min_delta": 0.01,
      "min_cov": 0.1,
      "min_increment": 0.01,
      "output_candidate_family": true,
      "max_category_combos": 3,
      "dedup_overlap_threshold": 0.8
    },
    "diff_numeric": {
      "_comment": "连续差异计算：effect_size 超过此阈值视为显著",
      "effect_size_significant_threshold": 0.2,
      "w_effect_size": 0.5,
      "w_delta_median": 0.3,
      "w_delta_p95": 0.2
    },
    "diff_categorical": {
      "_comment": "离散差异计算：返回前 top_k 个差异最大类别",
      "top_k": 3
    }
  },
  "stage2": {
    "_comment": "阶段2：原子规则、Beam Search、客群评分与组合",
    "max_features_per_segment": 3,
    "top_k_features": 30,
    "beam_size": 20,
    "top_n_candidates": 30,
    "max_segments": 5,
    "overlap_max": 0.6,
    "different_field_overlap": 0.3,
    "min_stability_score": 0.3,
    "min_divergence_score": 0.1,
    "min_rules_per_segment": 2,
    "similarity_threshold": 0.95,
    "similarity_fallback_thresholds": [0.95, 0.9, 0.85],
    "w_effect_size": 0.4,
    "w_delta_mean": 0.3,
    "w_quantile_shift": 0.2,
    "w_significance": 0.1,
    "stability_w_std": 0.4,
    "stability_w_kurtosis": 0.3,
    "stability_w_sample": 0.3,
    "beam_w_divergence": 0.5,
    "beam_w_stability": 0.3,
    "beam_w_diversity": 0.2,
    "lift_min": 1.5,
    "min_delta": 0.02,
    "max_categories": 5,
    "atomic_rules": {
      "use_candidate_family_first": true,
      "max_atomic_per_column": 5,
      "fallback_to_legacy_rec": true
    },
    "unified_scoring": {
      "use_unified_scoring": true,
      "w1_precision": 0.38,
      "w2_lift": 0.27,
      "w3_all_cov_penalty": 0.12,
      "w4_instability_penalty": 0.10,
      "w5_redundancy_penalty": 0.05,
      "w6_proxy_penalty": 0.05,
      "w7_diversity_bonus": 0.05,
      "cov_penalty_threshold": 0.35,
      "stability_floor": 0.2,
      "redundancy_similarity_threshold": 0.9
    },
    "expected_cohort_ratio": 0.01,
    "enable_precision_filter": true,
    "min_atomic_rules_for_search": 30,
    "max_base_cov": 0.42,
    "allow_main_for_beam": true,
    "main_max_base_cov": 0.30,
    "categorical_max_base_cov": 0.40,
    "fallback_max_base_cov": 0.5,
    "min_sub_cov": 0.02,
    "min_lift_atomic": 1.05,
    "fallback_min_lift_atomic": 1.05,
    "min_precision_mult": 1,
    "max_combo_cov_est": 0.15,
    "expand_combo_cov_max": 0.15,
    "require_rare_anchor": true,
    "rare_anchor_base_cov": 0.35,
    "min_combo_precision": 0.01,
    "require_exact_k": false,
    "allow_missing_pi": false,
    "pair_assoc_path": null,
    "pair_redundant_thr": 0.7,
    "pair_conflict_thr": 0.8,
    "pair_conflict_sign": -1,
    "pair_redundant_types": ["cont_cont_linear", "cont_cont_rank"],
    "enable_pair_assoc_pruning": true,
    "pair_assoc_min_support": 200,
    "pair_assoc_hard_thr": 0.85,
    "corr_prune_th": 0.85,
    "pair_assoc_soft_thr": 0.65,
    "combo_cov_gamma": 1.0,
    "pair_assoc_soft_penalty": 0.15,
    "pair_assoc_conflict_mode": "off",
    "assoc_inflation_alpha": 0.3,
    "precision_range_delta": 0.1,
    "inflation_cap": 2.0,
    "min_cov_lb_floor": 1e-9,
    "precision_ub_cap": 0.99,
    "expand_require_discrete": false,
    "selection_w_dist": 0.6,
    "selection_w_quality": 0.4,
    "selection_min_score": null,
    "selection_overlap_shared_fields_max": 1,
    "selection_jaccard_dist_min": 0.5,
    "cov_shrunk_missing_penalty": 0.8,
    "target_precision_min": 0,
    "target_coverage_min": 0,
    "target_segment_count": null,
    "target_user_count_10k": null,
    "use_f1_balance": true,
    "target_priority": "f1",
    "total_population": null,
    "output_max_segments": 10,
    "max_estimated_users": null,
    "max_combo_cov_est_menu": null,
    "min_estimated_users": null,
    "dedup": {
      "same_structure_at_candidate": true,
      "same_structure_at_portfolio": true
    },
    "clustering": {
      "cluster_by": "",
      "max_per_cluster_first": 1,
      "min_clusters_represented": 2
    },
    "output": {
      "include_anchor_feature": true,
      "include_feature_clusters": true,
      "include_score_breakdown": true,
      "include_redundancy_group_id": true,
      "include_selection_reason": true,
      "menu_contains_all_recommended": true
    },
    "risk_scoring": {
      "enabled": true,
      "tier_weights": { "strong": 3, "medium": 2, "weak": 1 },
      "use_rule_score_directly": true
    },
    "_coverage_tuning": "见 docs/coverage_tuning_guide.md"
  }
}
